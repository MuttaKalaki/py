import pandas as pd
data = {
    "Name": ["Alice", "Bob", "Charlie", "David", "Eva", "Frank", "Grace"],
    "Gender": ["Female", "Male", "Male", "Male", "Female", "Male", "Female"],
    "Maths": [85, 78, 92, 70, 88, 76, 95],
    "Science": [90, 74, 89, 65, 91, 72, 98],
    "English": [88, 80, 85, 60, 87, 75, 93]
}

df = pd.DataFrame(data)

print("Student DataFrame:\n")
print(df)
print("\nMean Marks:")
print(df[["Maths", "Science", "English"]].mean())
print("\nMaximum Marks:")
print(df[["Maths", "Science", "English"]].max())
print("\nMinimum Marks:")
print(df[["Maths", "Science", "English"]].min())
print("\nStatistical Summary using describe():")
print(df[["Maths", "Science", "English"]].describe())
print("\nGender Count:")
print(df["Gender"].value_counts())
